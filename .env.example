# Copy to .env and fill in.
# Generate PIN_HASH:   uv run python -m bus_zeiterfassung.auth hash 1234
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"

PIN_HASH=
SECRET_KEY=
TZ=Europe/Berlin

# Path to the Excel template (relative to repo root or absolute).
TEMPLATE_PATH=data/Dienstzeitblatt_template.xlsx

# SQLite DB file.
DATABASE_URL=sqlite:///data/db.sqlite3

# Directory where generated xlsx + pdf exports are stored.
EXPORT_DIR=data/exports
